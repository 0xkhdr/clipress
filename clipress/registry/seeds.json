{
  "version": "1.1",
  "seeds": {
    "git status":    { "strategy": "keyvalue",  "params": { "max_lines": 15 },                            "streamable": false },
    "git diff":      { "strategy": "diff",      "params": { "max_lines": 80, "context_lines": 2 },        "streamable": false },
    "git log":       { "strategy": "list",      "params": { "max_lines": 20 },                            "streamable": false },
    "git push":      { "strategy": "progress",  "params": { "keep": "final_line" },                       "streamable": false },
    "git pull":      { "strategy": "progress",  "params": { "keep": "final_line" },                       "streamable": false },
    "git stash":     { "strategy": "list",      "params": { "max_lines": 10 },                            "streamable": false },
    "docker ps":     { "strategy": "table",     "params": { "max_rows": 15 },                             "streamable": false },
    "docker build":  { "strategy": "progress",  "params": { "keep": "errors_and_final" },                 "streamable": true  },
    "docker logs":   { "strategy": "list",      "params": { "dedup": true, "tail_lines": 30 },            "streamable": false },
    "docker images": { "strategy": "table",     "params": { "max_rows": 20 },                             "streamable": false },
    "pytest":        { "strategy": "test",      "params": { "keep": "failed_only" },                      "streamable": false },
    "jest":          { "strategy": "test",      "params": { "keep": "failed_only" },                      "streamable": false },
    "cargo test":    { "strategy": "test",      "params": { "keep": "failed_only" },                      "streamable": false },
    "npm install":   { "strategy": "progress",  "params": { "keep": "final_line" },                       "streamable": true  },
    "pip install":   { "strategy": "progress",  "params": { "keep": "final_line" },                       "streamable": true  },
    "cargo build":   { "strategy": "progress",  "params": { "keep": "errors_and_final" },                 "streamable": true  },
    "npm run build": { "strategy": "progress",  "params": { "keep": "errors_and_final" },                 "streamable": true  },
    "ls":            { "strategy": "list",      "params": { "max_lines": 30 },                            "streamable": false },
    "find":          { "strategy": "list",      "params": { "group_by_directory": true },                 "streamable": false },
    "cat":           { "strategy": "list",      "params": { "max_lines": 50 },                            "streamable": false }
  }
}
